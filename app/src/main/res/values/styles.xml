<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.UnifiedComms" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/material_dynamic_primary40</item>
        <item name="colorPrimaryContainer">@color/material_dynamic_primaryContainer40</item>
        <item name="colorOnPrimary">@color/material_dynamic_onPrimary40</item>
        <item name="colorOnPrimaryContainer">@color/material_dynamic_onPrimaryContainer40</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/material_dynamic_secondary40</item>
        <item name="colorSecondaryContainer">@color/material_dynamic_secondaryContainer40</item>
        <item name="colorOnSecondary">@color/material_dynamic_onSecondary40</item>
        <item name="colorOnSecondaryContainer">@color/material_dynamic_onSecondaryContainer40</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- ponytail: appearance (light/dark icons) is driven dynamically from the
             active theme in MainActivity via WindowInsetsController, not a static flag. -->
        <!-- Window background -->
        <item name="android:windowBackground">@color/material_dynamic_background40</item>
        <!-- Ripple -->
        <item name="colorControlHighlight">@color/material_dynamic_primaryContainer40</item>
    </style>

    <!-- Full-screen reminder theme -->
    <style name="Theme.UnifiedComms.FullScreenReminder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/material_dynamic_primary40</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Transparent theme for OAuth callback -->
    <style name="Theme.UnifiedComms.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.UnifiedComms.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/material_dynamic_primary40</item>
    </style>

    <!-- Dialog theme -->
    <style name="Theme.UnifiedComms.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <!-- Bottom sheet theme -->
    <style name="Theme.UnifiedComms.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.UnifiedComms.BottomSheet.Modal</item>
    </style>

    <style name="Widget.UnifiedComms.BottomSheet.Modal" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.UnifiedComms.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.UnifiedComms.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.UnifiedComms.Chip" parent="Widget.MaterialComponents.Chip.Entry">
        <item name="chipCornerRadius">16dp</item>
        <item name="chipMinHeight">40dp</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.UnifiedComms.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.UnifiedComms.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Text field style -->
    <style name="Widget.UnifiedComms.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.UnifiedComms.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Navigation bar style -->
    <style name="Widget.UnifiedComms.NavigationBar" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemHorizontalPadding">12dp</item>
    </style>
</resources>