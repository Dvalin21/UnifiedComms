<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tasks Widget Configuration"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select task lists to show in widget:"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/accounts_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp" />

            <CheckBox
                android:id="@+id/show_completed_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show completed tasks"
                android:layout_marginBottom="12dp" />

            <CheckBox
                android:id="@+id/filter_overdue_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overdue only"
                android:layout_marginBottom="12dp" />

            <CheckBox
                android:id="@+id/filter_today_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Due today only"
                android:layout_marginBottom="12dp" />

            <CheckBox
                android:id="@+id/filter_starred_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Starred only"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Max tasks:"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />

                <EditText
                    android:id="@+id/max_tasks_input"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="2"
                    android:text="5"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/save_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_marginTop="16dp" />

</LinearLayout>